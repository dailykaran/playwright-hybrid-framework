{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "noUnusedLocals": false,
      "noUnusedParameters": false
    },
    "transpileOnly": true,
    "experimentalEsm": false
  }
}
